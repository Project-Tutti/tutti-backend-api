<?xml version="1.0" encoding="UTF-8"?>
<!-- ══════════════════════════════════════════════════════════════
     Tutti — Logback Configuration
     ══════════════════════════════════════════════════════════════
     • local/dev: 컬러 콘솔 + 읽기 쉬운 포맷
     • prod:      JSON 구조화 로그 (LogstashEncoder — Loki/Promtail 완전 호환)
     ══════════════════════════════════════════════════════════════ -->
<configuration>

    <property name="APP_NAME" value="tutti-main-server"/>

    <!-- ────────────────────────────────────────────────────
         Profile: local, dev — 컬러 콘솔 포맷
         ──────────────────────────────────────────────────── -->
    <springProfile name="local | dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <!-- 타임스탬프(HH:mm:ss) | 로그레벨 | 스레드 | 클래스.메서드 | 메시지 -->
                <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan([%-15.15thread]) %boldYellow(%-40.40logger{39}) %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ────────────────────────────────────────────────────
         Profile: prod — JSON 구조화 로그 (LogstashEncoder)
         ────────────────────────────────────────────────────
         • 모든 특수 문자(\n, \t, ", \) 완벽 JSON escape
         • MDC 필드 자동 포함 (httpMethod, requestUri, httpStatus, durationMs 등)
         • Promtail/Loki에서 필드 기반 필터링 즉시 가능
         ──────────────────────────────────────────────────── -->
    <springProfile name="prod">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <timeZone>Asia/Seoul</timeZone>
                <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampPattern>
                <!-- 불필요한 기본 필드 제외 (Loki 저장 공간 절약) -->
                <fieldNames>
                    <version>[ignore]</version>
                </fieldNames>
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>

        <!-- 애플리케이션 로그는 INFO 이상 -->
        <logger name="com.tutti.server" level="INFO" additivity="false">
            <appender-ref ref="JSON_CONSOLE"/>
        </logger>
    </springProfile>

</configuration>
